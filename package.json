{
  "name": "crond-js",
  "version": "1.0.0",
  "description": "Project-local cron daemon that reads a standard crontab file",
  "type": "module",
  "bin": {
    "crond-js": "./dist/cli.js",
    "crond-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test:unit": "vitest run test/unit/",
    "test:e2e": "vitest run test/e2e/ --testTimeout=120000",
    "test": "vitest run",
    "test:integration": "bash test/integration/claude-cron.sh",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "cron",
    "daemon",
    "mcp",
    "crontab"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "croner": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
